<!-- REPORTS ANALYTICS VIEW -->

<!-- ChartJS CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="page-header">
  <div class="welcome-section">
    <h1>Laporan Keuangan</h1>
    <p>Visualisasi grafik perbandingan pemasukan, pengeluaran, dan porsi kategori transaksi Anda.</p>
  </div>
  <div class="header-actions">
    <button class="btn btn-primary trigger-add-expense">
      <i data-lucide="plus"></i>
      <span>Catat Transaksi</span>
    </button>
  </div>
</div>

<div class="charts-grid" style="display: flex; flex-direction: column; gap: 1.5rem;">

  <!-- Upper Row: Monthly Trend Line Chart (Full Width) -->
  <div class="section-card">
    <div class="section-header">
      <h3 class="section-title">
        <i data-lucide="trending-up"></i>
        <span>Tren Pemasukan vs Pengeluaran Harian (30 Hari Terakhir)</span>
      </h3>
    </div>
    
    <% if @daily_trend.all? { |d| d[:total] == 0.0 && d[:income_total] == 0.0 } %>
      <div class="empty-state" style="padding: 5rem 0;">
        <i data-lucide="line-chart" style="font-size: 3rem;"></i>
        <p>Belum ada tren keuangan untuk ditampilkan.</p>
        <p style="font-size: 0.85rem; margin-top: 0.25rem;">Catatan transaksi baru akan melacak statistik tren pemasukan dan pengeluaran secara realtime.</p>
      </div>
    <% else %>
      <div class="chart-container" style="height: 350px;">
        <canvas id="trendChart"></canvas>
      </div>
    <% end %>
  </div>

  <!-- Tabs Selector for Category Distribution -->
  <div class="report-tabs" style="display: flex; gap: 0.5rem; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-color); padding: 0.35rem; border-radius: var(--radius-md); width: max-content; align-self: flex-start;">
    <button class="report-tab-btn active" data-tab="expense" style="background: rgba(244, 63, 94, 0.15); border: 1px solid rgba(244, 63, 94, 0.3); color: var(--accent-danger); font-family: var(--font-sans); font-size: 0.9rem; font-weight: 700; cursor: pointer; padding: 0.5rem 1.25rem; border-radius: calc(var(--radius-md) - 6px); transition: var(--transition);">
      <i data-lucide="arrow-down-right" style="width: 14px; height: 14px; display: inline-block; vertical-align: middle; margin-right: 0.3rem;"></i>
      Distribusi Pengeluaran
    </button>
    <button class="report-tab-btn" data-tab="income" style="background: none; border: 1px solid transparent; color: var(--text-secondary); font-family: var(--font-sans); font-size: 0.9rem; font-weight: 600; cursor: pointer; padding: 0.5rem 1.25rem; border-radius: calc(var(--radius-md) - 6px); transition: var(--transition);">
      <i data-lucide="arrow-up-right" style="width: 14px; height: 14px; display: inline-block; vertical-align: middle; margin-right: 0.3rem;"></i>
      Distribusi Pemasukan
    </button>
  </div>

  <!-- Lower Row: Expense Breakdown (Visible by default) -->
  <div id="expense-report-section" class="report-section-content active">
    <div style="display: grid; grid-template-columns: 1.2fr 1.8fr; gap: 1.5rem; width: 100%;" class="charts-grid-lower">
      
      <!-- Left Panel: Doughnut Chart -->
      <div class="section-card" style="display: flex; flex-direction: column;">
        <div class="section-header">
          <h3 class="section-title">
            <i data-lucide="pie-chart" style="color: var(--accent-danger);"></i>
            <span>Porsi Pengeluaran (Bulan Ini)</span>
          </h3>
        </div>
        
        <% if @category_chart.empty? %>
          <div class="empty-state" style="flex-grow: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 0;">
            <i data-lucide="activity" style="font-size: 3rem;"></i>
            <p>Belum ada data pengeluaran bulan ini.</p>
          </div>
        <% else %>
          <div class="chart-container" style="height: 260px; margin: auto;">
            <canvas id="categoryChart"></canvas>
          </div>
        <% end %>
      </div>

      <!-- Right Panel: Data Grid List -->
      <div class="section-card" style="display: flex; flex-direction: column; justify-content: space-between;">
        <div class="section-header">
          <h3 class="section-title">
            <i data-lucide="list-checks" style="color: var(--accent-danger);"></i>
            <span>Rincian Pengeluaran per Kategori</span>
          </h3>
        </div>
        
        <% if @category_chart.empty? %>
          <div class="empty-state" style="padding: 4rem 0;">
            <p>Belum ada pengeluaran dicatat bulan ini.</p>
          </div>
        <% else %>
          <div style="display: flex; flex-direction: column; gap: 0.75rem; flex-grow: 1;">
            <% 
              total_sum = @category_chart.sum { |c| c[:total] }
              @category_chart.each do |c|
                percent = total_sum > 0 ? (c[:total] / total_sum * 100).round : 0
            %>
              <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1rem; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border-color); border-radius: var(--radius-md);">
                <span style="display: flex; align-items: center; gap: 0.6rem; font-weight: 500;">
                  <span style="width: 10px; height: 10px; border-radius: 50%; display: inline-block;" class="<%= category_color_class(c[:category]) %>"></span>
                  <%= c[:category] %>
                </span>
                <div style="text-align: right;">
                  <div style="font-weight: 700; color: var(--text-primary);"><%= format_idr(c[:total]) %></div>
                  <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.1rem;"><%= percent %>% dari seluruh pengeluaran</div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Lower Row: Income Breakdown (Hidden by default) -->
  <div id="income-report-section" class="report-section-content" style="display: none;">
    <div style="display: grid; grid-template-columns: 1.2fr 1.8fr; gap: 1.5rem; width: 100%;" class="charts-grid-lower">
      
      <!-- Left Panel: Doughnut Chart -->
      <div class="section-card" style="display: flex; flex-direction: column;">
        <div class="section-header">
          <h3 class="section-title">
            <i data-lucide="pie-chart" style="color: var(--accent-success);"></i>
            <span>Porsi Pemasukan (Bulan Ini)</span>
          </h3>
        </div>
        
        <% if @income_category_chart.empty? %>
          <div class="empty-state" style="flex-grow: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 0;">
            <i data-lucide="activity" style="font-size: 3rem;"></i>
            <p>Belum ada data pemasukan bulan ini.</p>
          </div>
        <% else %>
          <div class="chart-container" style="height: 260px; margin: auto;">
            <canvas id="incomeCategoryChart"></canvas>
          </div>
        <% end %>
      </div>

      <!-- Right Panel: Data Grid List -->
      <div class="section-card" style="display: flex; flex-direction: column; justify-content: space-between;">
        <div class="section-header">
          <h3 class="section-title">
            <i data-lucide="list-checks" style="color: var(--accent-success);"></i>
            <span>Rincian Pemasukan per Kategori</span>
          </h3>
        </div>
        
        <% if @income_category_chart.empty? %>
          <div class="empty-state" style="padding: 4rem 0;">
            <p>Belum ada pemasukan dicatat bulan ini.</p>
          </div>
        <% else %>
          <div style="display: flex; flex-direction: column; gap: 0.75rem; flex-grow: 1;">
            <% 
              total_income_sum = @income_category_chart.sum { |c| c[:total] }
              @income_category_chart.each do |c|
                percent = total_income_sum > 0 ? (c[:total] / total_income_sum * 100).round : 0
            %>
              <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1rem; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border-color); border-radius: var(--radius-md);">
                <span style="display: flex; align-items: center; gap: 0.6rem; font-weight: 500;">
                  <span style="width: 10px; height: 10px; border-radius: 50%; display: inline-block;" class="<%= category_color_class(c[:category]) %>"></span>
                  <%= c[:category] %>
                </span>
                <div style="text-align: right;">
                  <div style="font-weight: 700; color: var(--text-primary);"><%= format_idr(c[:total]) %></div>
                  <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.1rem;"><%= percent %>% dari seluruh pemasukan</div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

</div>

<!-- CHART.JS LOGIC SCRIPT -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  // 0. Tabs toggle logic
  const tabs = document.querySelectorAll('.report-tab-btn');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Deactivate all tabs
      tabs.forEach(t => {
        t.classList.remove('active');
        t.style.background = 'none';
        t.style.border = '1px solid transparent';
        t.style.color = 'var(--text-secondary)';
        t.style.fontWeight = '600';
      });

      // Hide all content sections
      document.querySelectorAll('.report-section-content').forEach(sect => {
        sect.style.display = 'none';
      });

      // Activate clicked tab
      tab.classList.add('active');
      const targetTab = tab.getAttribute('data-tab');
      const contentSection = document.getElementById(`${targetTab}-report-section`);
      if (contentSection) contentSection.style.display = 'block';

      // Style active tab button
      if (targetTab === 'expense') {
        tab.style.background = 'rgba(244, 63, 94, 0.15)';
        tab.style.border = '1px solid rgba(244, 63, 94, 0.3)';
        tab.style.color = 'var(--accent-danger)';
        tab.style.fontWeight = '700';
      } else {
        tab.style.background = 'rgba(16, 185, 129, 0.15)';
        tab.style.border = '1px solid rgba(16, 185, 129, 0.3)';
        tab.style.color = 'var(--accent-success)';
        tab.style.fontWeight = '700';
      }
    });
  });

  // Check if charts elements exist in the view
  const trendCanvas = document.getElementById('trendChart');
  const categoryCanvas = document.getElementById('categoryChart');
  const incomeCategoryCanvas = document.getElementById('incomeCategoryChart');

  // Chart Global Style Tweaks for Dark Theme
  Chart.defaults.color = 'rgba(255, 255, 255, 0.6)';
  Chart.defaults.font.family = "'Outfit', sans-serif";

  // Category Color Map matching CSS
  const categoryColors = {
    'Makanan & Minuman': '#f97316',
    'Transportasi': '#3b82f6',
    'Tagihan & Utilitas': '#10b981',
    'Hiburan & Rekreasi': '#8b5cf6',
    'Belanja': '#ec4899',
    'Kesehatan': '#ef4444',
    'Gaji': '#10b981',
    'Investasi': '#0ea5e9',
    'Wirausaha': '#f59e0b',
    'Lainnya': '#64748b'
  };

  // 1. Setup Trend Chart (Multi-Line Chart)
  if (trendCanvas) {
    const dailyLabels = <%= @daily_trend.map { |d| d[:formatted_date] }.to_json %>;
    const dailyTotals = <%= @daily_trend.map { |d| d[:total] }.to_json %>; // Expenses
    const dailyIncomeTotals = <%= @daily_trend.map { |d| d[:income_total] }.to_json %>; // Incomes

    new Chart(trendCanvas, {
      type: 'line',
      data: {
        labels: dailyLabels,
        datasets: [
          {
            label: 'Pengeluaran (Rp)',
            data: dailyTotals,
            borderColor: '#ef4444',
            borderWidth: 3,
            backgroundColor: 'rgba(239, 68, 68, 0.05)',
            fill: true,
            tension: 0.3,
            pointBackgroundColor: '#ef4444',
            pointRadius: 2,
            pointHoverRadius: 6
          },
          {
            label: 'Pemasukan (Rp)',
            data: dailyIncomeTotals,
            borderColor: '#10b981',
            borderWidth: 3,
            backgroundColor: 'rgba(16, 185, 129, 0.05)',
            fill: true,
            tension: 0.3,
            pointBackgroundColor: '#10b981',
            pointRadius: 2,
            pointHoverRadius: 6
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: true,
            position: 'top',
            labels: {
              padding: 15,
              usePointStyle: true,
              pointStyle: 'circle'
            }
          },
          tooltip: {
            backgroundColor: '#1e293b',
            titleColor: '#fff',
            bodyColor: '#fff',
            borderColor: 'rgba(255, 255, 255, 0.1)',
            borderWidth: 1,
            callbacks: {
              label: function(context) {
                let label = context.dataset.label || '';
                if (label) {
                  label += ': ';
                }
                if (context.parsed.y !== null) {
                  label += new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(context.parsed.y);
                }
                return label;
              }
            }
          }
        },
        scales: {
          x: {
            grid: {
              color: 'rgba(255, 255, 255, 0.03)',
              borderColor: 'rgba(255, 255, 255, 0.05)'
            }
          },
          y: {
            beginAtZero: true,
            grid: {
              color: 'rgba(255, 255, 255, 0.03)',
              borderColor: 'rgba(255, 255, 255, 0.05)'
            },
            ticks: {
              callback: function(value, index, values) {
                if (value >= 1000000) {
                  return 'Rp ' + (value / 1000000).toFixed(1) + 'jt';
                } else if (value >= 1000) {
                  return 'Rp ' + (value / 1000).toFixed(0) + 'rb';
                }
                return 'Rp ' + value;
              }
            }
          }
        }
      }
    });
  }

  // 2. Setup Expense Category Chart (Doughnut)
  if (categoryCanvas) {
    const rawCategories = <%= @category_chart.to_json %>;
    const labels = rawCategories.map(c => c.category);
    const totals = rawCategories.map(c => c.total);
    const colors = labels.map(label => categoryColors[label] || '#64748b');

    new Chart(categoryCanvas, {
      type: 'doughnut',
      data: {
        labels: labels,
        datasets: [{
          data: totals,
          backgroundColor: colors,
          borderWidth: 2,
          borderColor: '#0f172a',
          hoverOffset: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              padding: 15,
              usePointStyle: true,
              pointStyle: 'circle'
            }
          },
          tooltip: {
            backgroundColor: '#1e293b',
            titleColor: '#fff',
            bodyColor: '#fff',
            borderColor: 'rgba(255, 255, 255, 0.1)',
            borderWidth: 1,
            callbacks: {
              label: function(context) {
                let label = context.label || '';
                if (label) {
                  label += ': ';
                }
                if (context.parsed !== null) {
                  label += new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(context.parsed);
                }
                return label;
              }
            }
          }
        },
        cutout: '70%'
      }
    });
  }

  // 3. Setup Income Category Chart (Doughnut)
  if (incomeCategoryCanvas) {
    const rawIncomeCategories = <%= @income_category_chart.to_json %>;
    const labels = rawIncomeCategories.map(c => c.category);
    const totals = rawIncomeCategories.map(c => c.total);
    const colors = labels.map(label => categoryColors[label] || '#64748b');

    new Chart(incomeCategoryCanvas, {
      type: 'doughnut',
      data: {
        labels: labels,
        datasets: [{
          data: totals,
          backgroundColor: colors,
          borderWidth: 2,
          borderColor: '#0f172a',
          hoverOffset: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              padding: 15,
              usePointStyle: true,
              pointStyle: 'circle'
            }
          },
          tooltip: {
            backgroundColor: '#1e293b',
            titleColor: '#fff',
            bodyColor: '#fff',
            borderColor: 'rgba(255, 255, 255, 0.1)',
            borderWidth: 1,
            callbacks: {
              label: function(context) {
                let label = context.label || '';
                if (label) {
                  label += ': ';
                }
                if (context.parsed !== null) {
                  label += new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(context.parsed);
                }
                return label;
              }
            }
          }
        },
        cutout: '70%'
      }
    });
  }
});
</script>

<style>
/* Responsive tweaks specifically for reports grids */
@media (max-width: 767px) {
  .charts-grid-lower {
    grid-template-columns: 1fr !important;
  }
}
</style>
