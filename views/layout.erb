<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DompetHarian - Catatan Pengeluaran Harian</title>
  
  <!-- CSS Link -->
  <link rel="stylesheet" href="/css/style.css">
  
  <!-- Lucide Icons CDN -->
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>

  <div class="app-container">
    
    <!-- 1. DESKTOP SIDEBAR -->
    <aside class="sidebar">
      <div class="brand">
        <div class="brand-icon">
          <i data-lucide="wallet"></i>
        </div>
        <span class="brand-name">DompetHarian</span>
      </div>

      <ul class="nav-menu">
        <li class="nav-item">
          <a href="/">
            <i data-lucide="layout-dashboard"></i>
            <span>Dashboard</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="/expenses">
            <i data-lucide="receipt"></i>
            <span>Riwayat Transaksi</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="/reports">
            <i data-lucide="pie-chart"></i>
            <span>Laporan Keuangan</span>
          </a>
        </li>
      </ul>

      <div class="sidebar-footer">
        <button class="btn btn-primary trigger-add-expense" style="width: 100%; margin-bottom: 1.5rem;">
          <i data-lucide="plus-circle"></i>
          <span>Tambah Transaksi</span>
        </button>
        
        <div class="user-profile" style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div class="avatar"><%= user_initials(current_user['username']) %></div>
            <div class="profile-info">
              <span class="username" title="<%= current_user['username'] %>">
                <%= current_user['username'].length > 12 ? current_user['username'][0..10] + '..' : current_user['username'] %>
              </span>
              <span class="user-role">Pengguna</span>
            </div>
          </div>
          <form action="/logout" method="POST" style="margin: 0;">
            <button type="submit" class="btn-logout" title="Keluar Akun">
              <i data-lucide="log-out"></i>
            </button>
          </form>
        </div>
      </div>
    </aside>

    <!-- 2. MOBILE BOTTOM NAVBAR -->
    <nav class="mobile-nav">
      <a href="/" class="mobile-nav-item">
        <i data-lucide="layout-dashboard"></i>
        <span>Beranda</span>
      </a>
      <a href="/expenses" class="mobile-nav-item">
        <i data-lucide="receipt"></i>
        <span>Riwayat</span>
      </a>
      <button class="mobile-nav-item add-btn-center trigger-add-expense">
        <i data-lucide="plus"></i>
      </button>
      <a href="/reports" class="mobile-nav-item">
        <i data-lucide="pie-chart"></i>
        <span>Laporan</span>
      </a>
    </nav>

    <!-- 3. MAIN CONTENT CONTAINER -->
    <main class="main-content">
      
      <!-- Flash notifications (for non-AJAX operations) -->
      <% if session[:success] %>
        <div class="notification success show" style="position: relative; bottom: auto; right: auto; transform: none; margin-bottom: 1rem;">
          <i data-lucide="check-circle"></i>
          <span><%= session.delete(:success) %></span>
        </div>
      <% end %>
      <% if session[:error] %>
        <div class="notification error show" style="position: relative; bottom: auto; right: auto; transform: none; margin-bottom: 1rem;">
          <i data-lucide="alert-circle"></i>
          <span><%= session.delete(:error) %></span>
        </div>
      <% end %>

      <!-- Dynamic Child Views -->
      <%= yield %>

    </main>

  </div>

  <!-- 4. ADD TRANSACTION MODAL (SHARED) -->
  <div class="modal-overlay" id="add-expense-modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Tambah Catatan Transaksi</h3>
        <button class="modal-close">&times;</button>
      </div>
      <div class="modal-body">
        <form id="expense-form" action="/expenses" method="POST">
          
          <div class="form-group">
            <label>Jenis Transaksi</label>
            <div class="transaction-type-toggle">
              <button type="button" class="type-toggle-btn active" data-type="expense">Pengeluaran</button>
              <button type="button" class="type-toggle-btn" data-type="income">Pemasukan</button>
            </div>
            <input type="hidden" id="transaction-type" name="type" value="expense">
          </div>

          <div class="form-group">
            <label for="expense-title">Nama Pengeluaran</label>
            <input type="text" id="expense-title" name="title" class="form-input" placeholder="e.g. Makan siang nasi padang" required maxlength="100">
          </div>

          <div class="form-group">
            <label for="expense-amount">Jumlah Pengeluaran (Rp)</label>
            <input type="number" id="expense-amount" name="amount" class="form-input" placeholder="e.g. 25000" min="1" step="any" required>
            <span id="amount-preview" style="font-size: 0.9rem; margin-top: 0.2rem; font-weight: 600;"></span>
          </div>

          <div class="form-group">
            <label for="expense-category">Kategori</label>
            <select id="expense-category" name="category" class="form-input" required>
              <option value="" disabled selected>Pilih Kategori</option>
              <option value="Makanan & Minuman">🍔 Makanan & Minuman</option>
              <option value="Transportasi">🚗 Transportasi</option>
              <option value="Tagihan & Utilitas">⚡ Tagihan & Utilitas</option>
              <option value="Hiburan & Rekreasi">🎮 Hiburan & Rekreasi</option>
              <option value="Belanja">🛍️ Belanja</option>
              <option value="Kesehatan">💊 Kesehatan</option>
              <option value="Lainnya">📦 Lainnya</option>
            </select>
          </div>

          <div class="form-group">
            <label for="expense-date">Tanggal</label>
            <input type="date" id="expense-date" name="date" class="form-input" required>
          </div>

          <div class="form-group">
            <label for="expense-notes">Catatan Tambahan (Opsional)</label>
            <textarea id="expense-notes" name="notes" class="form-input" placeholder="e.g. Catatan tambahan transaksi" rows="3"></textarea>
          </div>

          <button type="submit" class="btn btn-primary" style="margin-top: 0.5rem;">
            <i data-lucide="save"></i>
            <span>Simpan Catatan</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Client-side Logic File -->
  <script src="/js/app.js"></script>
</body>
</html>
